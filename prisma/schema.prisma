generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  
  settings  Settings?
  clients   Client[]
  scripts   Script[]
  uploads   Upload[]
  watchlistGroups WatchlistGroup[]
  history   History[]
  leads     Lead[]
  dmTemplates DmTemplate[]
  ideas     Idea[]
  carousels Carousel[]
  contentItems ContentItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  agencyName       String?  // To remember: "K for Kreative"
  agencyLogo       String?  // To store the URL of the uploaded logo
  geminiApiKey     String?
  apifyApiKey      String?
  openaiApiKey     String?
  anthropicApiKey  String?
  elevenlabsApiKey String?
  sarvamApiKey     String?
  notionApiKey     String?
  notionDatabaseId String?
  activeProvider   String?  @default("Gemini")
  activeModel      String?  @default("Gemini 2.5 Flash")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name              String
  niche             String?
  platform          String?  @default("Instagram")
  language          String?
  duration          String?
  targetAudience    String?
  tonePersona       String?
  vocabularyLevel   String?
  preferredTopics   String?
  avoidTopics       String?
  ctaStyle          String?
  customInstructions String? @db.Text
  /// Full pasted "master guide" for script voice, remix rules, anatomy — injected when this client is selected in Script Studio
  scriptMasterGuide  String?  @db.Text
  preferredHooks    Json?    // Array of hook objects
  examples          Json?    // Array of script examples
  trackedVideos     Json?    // Array of video data
  styleDNA          Json?    // Style analysis object
  gameMode          String?  @default("awareness") // "awareness" | "conversion"
  profileData       Json?    // { handle, bio, displayName, ctaLink, followers, picUrl, highlights[], lastFetchedAt }
  pcrAudit          Json?    // { score, grade, rewrites: {...}, alignmentFlag, updatedAt }
  strategyAudit     Json?    // { iva, platform, anchors[], patterns, gapReport, updatedAt }
  
  scripts           Script[]
  ideas             Idea[]
  carousels         Carousel[]
  contentItems      ContentItem[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([userId])
}

model Script {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  title         String
  content       String   @db.Text
  type          String?  // "Remix" or "Original"
  hooks         Json?    // A/B hooks state
  caption       String?  @db.Text
  repurposed    String?  @db.Text
  scriptJob     String?
  directorsCut  Json?
  prompts       Json?
  packaging     Json?
  metadata      Json?    // Editor settings + research + generated content
  contentItemId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([clientId])
}

model Upload {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName    String
  jobId       String?  @unique
  status      JobStatus @default(COMPLETED)
  analysis    Json?
  transcript  String? @db.Text
  thumbnail   String? @db.Text
  errorMessage String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model WatchlistGroup {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name      String
  channels  WatchlistChannel[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WatchlistChannel {
  id            String   @id @default(cuid())
  groupId       String
  group         WatchlistGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  username      String
  platform      String?  @default("Instagram")
  url           String?
  followers     Int?
  miningQuadrant String?
  profilePicUrl String?  @db.Text
  isVerified    Boolean? @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([groupId])
  @@unique([groupId, username])
}

model History {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  savedAt     DateTime @default(now())
  post        Json     // Instagram post data
  analysis    Json     // AI analysis data
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
}

model Lead {
  id          String   @id @default(cuid())
  userId      String
  handle      String
  niche       String?
  followers   String?
  templateId  String?  // References DmTemplate.id
  notes       String?
  status      String   @default("Prospect") // Prospect, DMed, Replied, Interested, Call booked, Closed, Dead
  priority    String   @default("Medium") // Low, Medium, High
  score       Int      @default(0)
  value       Int      @default(25000)
  dealValue   Int      @default(0) // Tracks the specific ₹ value of this lead
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model DmTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String?
  body        String   @db.Text
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model Idea {
  id          String   @id @default(cuid())
  userId      String
  clientId    String?
  title       String
  seed        String   @db.Text
  substance   String?  @db.Text
  angles      Json?
  contentItems ContentItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
}

model Carousel {
  id            String   @id @default(cuid())
  userId        String
  clientId      String?
  contentItemId String?
  title         String
  format        String
  slides        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contentItem   ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
}

model ContentItem {
  id           String    @id @default(cuid())
  userId       String
  clientId     String?
  type         String    @default("reel")
  status       String    @default("not_started")
  title        String
  pillar       String?
  scheduledAt  DateTime?
  postedAt     DateTime?
  publishedUrl String?
  ideaId       String?
  scriptId     String?
  carouselId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  idea         Idea?      @relation(fields: [ideaId], references: [id], onDelete: SetNull)
  carousels    Carousel[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, scheduledAt])
  @@index([clientId])
}
